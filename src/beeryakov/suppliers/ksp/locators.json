{
    "worlds": {
        "attrs": {"href":"text"} ,
        "by": "XPATH",
        "selector": "//a[contains(@href,'/web/world')]",
        "action":false
    },
    "subs_from_worlds":{
        "attrs":{"href":"text"},
        "by":"XPATH",
        "selector":"//h1/following-sibling::div[1]/div//a",
        "action":false
    },
    "open_full_brands_list":{
        "attrs":false,
        "by":"XPATH",
        "selector":"//div[contains(@aria-label,'פתחו') and contains(@aria-label,'עוד') and contains(@aria-label,'יצרן')]",
        "action":"click()" 
    },
    "get_brands_list":{
        "attrs":"innerText",
        "by":"XPATH",
        "selector":"//div[not (contains(@aria-label,'פתחו')) and not (contains(@aria-label,'עוד')) and contains(@aria-label,'יצרן')]/following-sibling::div[1]",
        "action": false
    }
}
{
  "product_links": {
    "attribute": "href",
    
    "by": "XPATH",
    "selector": "//div[contains(@style, 'grid-template-columns')]//a",
    
    "use_mouse": false, "mandatory": true,
    "action": null,
    "mandatory": true,
    "@note": "ссылки на страницы товаров"
  },


  "pagination": {
    "ul": {
      
      "attribute": null,
      "by": "XPATH",
      "selector": "//ul[@class='pagination']",
      "action": "click()",
      "mandatory":  false,
      "@note": "если некуда двигаться - драйвер вернет False"
    },
    "->": {
      "attribute": null,
      "by": "xpath",
      "selector": "//*[@class = 'ui-pagination-navi util-left']/a[@class='ui-pagination-next']",
      "action": "click()",
      "use_mouse": false, "mandatory": true,
      "mandatory": true,
      "@note": ""
    }
  }

}
